{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/sh \"${PLUGIN_ROOT}/hooks/record_event.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/sh \"${PLUGIN_ROOT}/hooks/record_event.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/sh \"${PLUGIN_ROOT}/hooks/record_event.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/sh \"${PLUGIN_ROOT}/hooks/record_event.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/sh \"${PLUGIN_ROOT}/hooks/record_event.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
